# ════════════════════════════════════════════════════════
# DGIIT | SECTURI — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales
# ════════════════════════════════════════════════════════

# ── Base de Datos MySQL ──────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO
DB_NAME=sgc_pro

# ── Servidor ─────────────────────────────────────────────
PORT=3000

# ── JWT (genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ──
JWT_SECRET=CAMBIAR_POR_CLAVE_SECRETA_LARGA_Y_ALEATORIA

# ── Correo Institucional (Gmail con App Password) ────────
EMAIL_USER=tu_cuenta@guanajuato.gob.mx
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
ADMIN_EMAIL=emartinezes@guanajuato.gob.mx

# ── VAPID Keys para Push Notifications ──────────────────
# Genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CAMBIAR_CLAVE_PUBLICA_VAPID
VAPID_PRIVATE_KEY=CAMBIAR_CLAVE_PRIVADA_VAPID
VAPID_MAILTO=mailto:tu_cuenta@guanajuato.gob.mx
